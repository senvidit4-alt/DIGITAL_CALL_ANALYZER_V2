# MCA Cyber Dost — Environment Variables Template
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore — never commit it.

# Flask
FLASK_ENV=development
FLASK_PORT=5000

# CORS — React dev server URL (P2 will give you this)
CORS_ORIGINS=http://localhost:5173

# ML model path (drop model.pkl here when P1 delivers it)
MODEL_PATH=model.pkl
